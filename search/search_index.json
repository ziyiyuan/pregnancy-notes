9C%9F%E7%94%9F%E6%B4%BB/%E5%AD%95%E6%9C%9F%E8%8F%9C%E5%8D%95/#_5","title":"\u8865\u5145\u5242","text":"\u65f6\u95f4 \u5185\u5bb9 \u65e9\u6668 \u7231\u4e50\u7ef4 2 \u6bb5 1 \u9897 \u4e0b\u5348 \u529b\u871a\u80fd 1 \u9897 \u7761\u524d \u9499\u7247 600 \u5355\u4f4d 1 \u7247 <p>\u4e2a\u4eba\u4e60\u60ef\uff1a\u4e0d\u7231\u5403\u575a\u679c\uff0c\u672a\u5355\u72ec\u5217\u5728\u83dc\u5355\u4e2d\u3002</p>"},{"location":"%E5%BE%85%E4%BA%A7%E5%8C%85%E5%87%86%E5%A4%87/%E5%8C%97%E5%8C%BB%E4%B8%89%E9%99%A2%E4%BA%A7%E7%A7%91%E5%85%A5%E9%99%A2%E6%B8%85%E5%8D%95/","title":"\u5317\u533b\u4e09\u9662\u4ea7\u79d1\u5165\u9662\u5206\u5a29\u51c6\u5907\u6e05\u5355","text":"<p>\u5206\u5a29\u533b\u9662\uff1a\u5317\u4eac\u5927\u5b66\u7b2c\u4e09\u533b\u9662\uff08\u5317\u533b\u4e09\u9662\uff09 \u6765\u6e90\uff1a\u5317\u533b\u4e09\u9662\u5987\u4ea7\u79d1\u516c\u4f17\u53f7\u3002\u4ee5\u4e0b\u6309\u533b\u9662\u8981\u6c42\u6574\u7406\uff0c\u4fbf\u4e8e\u6838\u5bf9\u51c6\u5907\u3002</p> <p>\u4f7f\u7528\u8bf4\u660e - \u4f4f\u9662\u65f6\u5e26\u53bb\u533b\u9662\uff1a01 \u5b9d\u5b9d\u7528\u54c1\uff08\u533b\u9662\u5f85\u4ea7\u5305\uff09\u300102 \u51c6\u5988\u5988\u7528\u54c1\uff08\u533b\u9662\u5f85\u4ea7\u5305\uff09\u300103 \u6240\u9700\u8bc1\u4ef6\u300104 \u51fa\u9662\u7528\u7269\uff08\u51fa\u9662\u5f53\u5929\u7a7f\u7684/\u7528\u7684\u53ef\u4e00\u5e76\u5e26\u53bb\uff09\u300105 \u996e\u98df\u51c6\u5907\uff08\u987b\u77e5\uff09\uff0c\u4ee5\u53ca\u300c\u9664\u533b\u9662\u5f85\u4ea7\u5305\u5916\u9700\u81ea\u5907\u300d\u8868\u683c\u4e2d\u7684\u5168\u90e8\u7269\u54c1\u3002\u6309\u6b64\u51c6\u5907\uff0c\u4f4f\u9662\u671f\u95f4\u8db3\u591f\u3002 - \u5c45\u5bb6\u4f7f\u7528\uff08\u4e0d\u5fc5\u5e26\u53bb\u533b\u9662\uff09\uff1a\u300c\u65b0\u751f\u513f\u524d 2 \u5468\u7528\u54c1\u6e05\u5355\uff08\u5c45\u5bb6\uff09\u300d\u4e3a\u51fa\u9662\u56de\u5bb6\u540e\u4f7f\u7528\uff0c\u63d0\u524d\u5907\u597d\u653e\u5728\u5bb6\u4e2d\u5373\u53ef\u3002</p>"},{"location":"%E5%BE%85%E4%BA%A7%E5%8C%85%E5%87%86%E5%A4%87/%E5%8C%97%E5%8C%BB%E4%B8%89%E9%99%A2%E4%BA%A7%E7%A7%91%E5%85%A5%E9%99%A2%E6%B8%85%E5%8D%95/#01","title":"01 \u5b9d\u5b9d\u7528\u54c1","text":"<ul> <li>\u8bf4\u660e\uff1a\u63a8\u8350\u5728\u533b\u9662\u5546\u5e97\u8d2d\u4e70\uff0c\u4e5f\u53ef\u81ea\u884c\u8d2d\u4e70\uff1b\u591a\u80ce\u8bf7\u6309\u5a74\u513f\u6570\u91cf\u51c6\u5907\u591a\u4efd\u3002</li> <li>\u533b\u9662\u5546\u5e97\u5a74\u513f\u7528\u54c1\u5305\uff08\u5355\u72ec\u552e\u5356\uff09\uff1a\u542b\u7532\u5305\u53ca\u5176\u4ed6\u7528\u7269\uff0c\u7528\u4e8e\u5b9d\u5b9d\u51fa\u751f\u540e\u5728\u4ea7\u540e\u75c5\u623f\u4f7f\u7528\u3002 \u7532\u5305\u5185\u5bb9\uff1a\u5b9d\u5b9d\u5e94\u5b63\u8863\u670d\u3001\u5c0f\u8925\u5b50\u3001\u7761\u888b\u3001\u5582\u5976\u8863\u3001\u5a74\u513f\u5e94\u5b63\u5305\u88ab\u3001\u5c0f\u6795\u5934\u3001\u65b9\u5dfe\u3001\u7eaf\u68c9\u5305\u5355\u3001\u7eb1\u5e03\u5305\u5355\u3001\u5a74\u513f\u7eb8\u5c3f\u88e4\u3001\u5a74\u513f\u8155\u5e26\u3001\u5a74\u513f\u6cb9\u3002</li> <li>\u5a74\u513f\u7528\u54c1\u4e59\u5305\uff1a\u4e0e\u6bcd\u4eb2\u5f85\u4ea7\u5305\u4e00\u8d77\u552e\u5356\uff0c\u6d88\u6bd2\u706d\u83cc\uff0c\u53ef\u5e26\u8fdb\u624b\u672f\u5ba4\u6216\u4ea7\u623f\u3002 \u4e59\u5305\u5185\u5bb9\uff1a\u5a74\u513f\u5e3d\u3001\u5b55\u5987\u5e3d\u3001\u5a74\u513f\u68c9\u88ab\u3001\u7eb1\u5e03\u5355\u5305\u3001\u5a74\u513f\u6d74\u5dfe\u3002</li> </ul>"},{"location":"%E5%BE%85%E4%BA%A7%E5%8C%85%E5%87%86%E5%A4%87/%E5%8C%97%E5%8C%BB%E4%B8%89%E9%99%A2%E4%BA%A7%E7%A7%91%E5%85%A5%E9%99%A2%E6%B8%85%E5%8D%95/#02","title":"02 \u51c6\u5988\u5988\u7528\u54c1","text":"<ul> <li>\u6bcd\u4eb2\u5f85\u4ea7\u5305\uff1a\u63a8\u8350\u5728\u533b\u9662\u5546\u5e97\u8d2d\u4e70\uff0c\u4e5f\u53ef\u81ea\u884c\u8d2d\u4e70\u3002</li> <li>\u6210\u4eba\u987a\u4ea7\u5305\uff1a\u5a74\u513f\u7528\u54c1\u4e59\u5305\u3001\u6210\u4eba\u7eb8\u5c3f\u88e4\u3001\u62a4\u7406\u57ab\u3001\u4e2d\u5355\u3001\u5c0f\u5355\u3001\u5a74\u513f\u7eaf\u68c9\u6d74\u5dfe\u3002</li> <li>\u6210\u4eba\u5256\u5bab\u4ea7\u5305\uff1a\u5a74\u513f\u7528\u54c1\u4e59\u5305\u3001\u6210\u4eba\u7eb8\u5c3f\u88e4\u3001\u62a4\u7406\u57ab\u3001\u4e2d\u5355\u3001\u8179\u5e26\u3001\u6c99\u888b\u3002</li> <li>\u6ce8\u610f\uff1a\u53cc\u80ce\u5b55\u5988\u5988\u65e0\u8bba\u987a\u4ea7\u8fd8\u662f\u5256\u5bab\u4ea7\u5747\u9700\u591a\u4e70\u4e00\u4efd\u4e59\u5305\u3002</li> <li>\u5176\u4ed6\u9700\u81ea\u884c\u51c6\u5907\uff1a\u80ce\u5fc3\u76d1\u62a4\u5e26\u3001\u53e3\u7f69\u3001\u6d17\u6f31\u7528\u54c1\u3001\u9910\u5177\u3001\u6c34\u676f\u3001\u5438\u7ba1\u3001\u591c\u7528\u536b\u751f\u5dfe 10\uff5e15 \u7247\u3001\u536b\u751f\u7eb8\u3001\u9632\u6ed1\u62d6\u978b\u3001\u5145\u7535\u5668\u3002   \u987a\u4ea7\u8fd8\u9700\u533b\u7528\u624b\u672f\u8584\u819c\uff08\u53ef\u5728\u533b\u9662\u5546\u5e97\u8d2d\u4e70\uff09\u3002</li> <li>\u6e29\u99a8\u63d0\u793a\uff1a\u5165\u9662\u524d\u5e94\u4fee\u526a\u6307\u7532\uff08\u8fc7\u957f\u6613\u5212\u4f24\u5b9d\u5b9d\uff09\uff0c\u7981\u6d82\u6307\u7532\u6cb9\u3002</li> </ul>"},{"location":"%E5%BE%85%E4%BA%A7%E5%8C%85%E5%87%86%E5%A4%87/%E5%8C%97%E5%8C%BB%E4%B8%89%E9%99%A2%E4%BA%A7%E7%A7%91%E5%85%A5%E9%99%A2%E6%B8%85%E5%8D%95/#03","title":"03 \u6240\u9700\u8bc1\u4ef6","text":"<ul> <li>\u8eab\u4efd\u8bc1</li> <li>\u4ea7\u68c0\u75c5\u5386\u539f\u4ef6</li> <li>\u533b\u4fdd\u5361</li> <li>\u5317\u4eac\u5e02\u6bcd\u5b50\u5065\u5eb7\u6863\u6848\u624b\u518c\uff08\u7eb8\u8d28\u7248\uff1b\u5982\u4e3a\u7535\u5b50\u7248\u53ef\u5ffd\u7565\u6b64\u9879\uff09</li> </ul>"},{"location":"%E5%BE%85%E4%BA%A7%E5%8C%85%E5%87%86%E5%A4%87/%E5%8C%97%E5%8C%BB%E4%B8%89%E9%99%A2%E4%BA%A7%E7%A7%91%E5%85%A5%E9%99%A2%E6%B8%85%E5%8D%95/#04","title":"04 \u51fa\u9662\u7528\u7269","text":"<ul> <li>\u5b9d\u5b9d\uff1a\u5e3d\u5b50 1 \u4e2a\u3001\u5b9d\u5b9d\u8863\u670d\u3001\u7eb8\u5c3f\u88e4\u3001\u5305\u88ab\uff08\u6839\u636e\u5b63\u8282\u9009\u62e9\uff09\u3002</li> <li>\u51c6\u5988\u5988\uff1a\u6839\u636e\u5b63\u8282\u5e26\u597d\u5408\u9002\u8863\u670d\uff08\u5efa\u8bae\u5bbd\u677e\u3001\u6613\u7a7f\u8131\u3001\u65b9\u4fbf\u54fa\u4e73\uff1b\u5256\u5bab\u4ea7\u6ce8\u610f\u907f\u514d\u6469\u64e6\u4f24\u53e3\uff09\u3002</li> </ul>"},{"location":"%E5%BE%85%E4%BA%A7%E5%8C%85%E5%87%86%E5%A4%87/%E5%8C%97%E5%8C%BB%E4%B8%89%E9%99%A2%E4%BA%A7%E7%A7%91%E5%85%A5%E9%99%A2%E6%B8%85%E5%8D%95/#05","title":"05 \u996e\u98df\u51c6\u5907","text":"<ul> <li>\u62e9\u671f\u624b\u672f\u60a3\u8005\uff1a\u624b\u672f\u5f53\u65e5 0:00 \u540e\u8bf7\u52ff\u8fdb\u98df\uff1b\u53ef\u559d\u6c34\u6216\u8f7b\u996e\u6599\uff08\u5982\u7535\u89e3\u8d28\u996e\u6599\uff09\u3002\u5165\u9662\u540e\u533b\u62a4\u4eba\u5458\u4f1a\u7ed9\u4e88\u4e2a\u6027\u5316\u6307\u5bfc\u3002</li> <li>\u4f4f\u9662\u671f\u95f4\uff1a\u4e3a\u4fdd\u969c\u6bcd\u5a74\u5b89\u5168\uff0c\u8bf7\u4e0d\u8981\u8ba2\u5916\u5356\u6216\u5bb6\u91cc\u9001\u9910\uff0c\u611f\u8c22\u914d\u5408\u3002</li> <li>\u6e29\u99a8\u63d0\u793a\uff1a\u672c\u9662\u4e3a\u7231\u5a74\u533b\u9662\uff0c\u63d0\u5021\u6bcd\u4e73\u5582\u517b\u3002\u4f4f\u9662\u671f\u95f4\u4e25\u7981\u643a\u5e26\u5976\u74f6\u3001\u5976\u7c89\u8fdb\u5165\u75c5\u623f\u3002</li> </ul> <p>\u5a74\u513f\u98df\u7269\u8bf4\u660e\uff08\u4f4f\u9662\u671f\u95f4\uff09 - \u4f4f\u9662\u671f\u95f4\u5a74\u513f\u4ee5\u6bcd\u4e73\u4e3a\u4e3b\uff1b\u5934\u51e0\u5929\u521d\u4e73\u91cf\u5c11\u5c5e\u6b63\u5e38\uff0c\u591a\u8ba9\u5b9d\u5b9d\u5438\u542e\u6709\u52a9\u5f00\u5976\u3002 - \u82e5\u533b\u751f\u8bc4\u4f30\u9700\u8981\u52a0\u5582\uff08\u5982\u4f4e\u8840\u7cd6\u3001\u4f53\u91cd\u4e0b\u964d\u7b49\uff09\uff0c\u7531\u533b\u9662\u63d0\u4f9b\u914d\u65b9\u5976\uff0c\u5e76\u7528\u533b\u9662\u5668\u5177\uff08\u5c0f\u676f/\u5c0f\u52fa\u6216\u533b\u9662\u7edf\u4e00\u5976\u74f6\uff09\u5728\u62a4\u58eb\u6307\u5bfc\u4e0b\u53bb\u5582\uff0c\u4e0d\u5f97\u4f7f\u7528\u81ea\u5e26\u7684\u5976\u74f6\u3001\u5976\u7c89\u3002\u5177\u4f53\u65b9\u5f0f\u53ef\u5165\u9662\u65f6\u5411\u4ea7\u79d1\u786e\u8ba4\u3002 - \u51fa\u9662\u56de\u5bb6\u540e\u82e5\u5976\u6c34\u4e0d\u8db3\uff0c\u53ef\u5148\u8ffd\u5976\uff08\u591a\u4eb2\u5582\u3001\u4fdd\u8bc1\u4f11\u606f\u4e0e\u6c34\u5206\uff09\uff1b\u82e5\u9700\u6df7\u5408\u5582\u517b\u518d\u8865\u914d\u65b9\u5976\u3002\u5efa\u8bae\u63d0\u524d\u5907\u597d\u5c0f\u7f50\u5976\u7c89\u4e0e\u5976\u74f6\uff08\u89c1\u4e0b\u65b9\u300c\u65b0\u751f\u513f\u524d 2 \u5468\u00b7\u5582\u517b\u300d\uff09\uff0c\u51fa\u9662\u540e\u624b\u8fb9\u5373\u6709\u3001\u4e0d\u5fc5\u4e34\u65f6\u518d\u4e70\u3002</p>"},{"location":"%E5%BE%85%E4%BA%A7%E5%8C%85%E5%87%86%E5%A4%87/%E5%8C%97%E5%8C%BB%E4%B8%89%E9%99%A2%E4%BA%A7%E7%A7%91%E5%85%A5%E9%99%A2%E6%B8%85%E5%8D%95/#_2","title":"\u9664\u533b\u9662\u5f85\u4ea7\u5305\u5916\u9700\u81ea\u5907\uff08\u6570\u91cf\uff09","text":"<p>\u82e5\u5df2\u8ba1\u5212\u8d2d\u4e70\u533b\u9662\u5f85\u4ea7\u5305\uff08\u987a\u4ea7\u5305/\u5256\u5bab\u4ea7\u5305 + \u5a74\u513f\u7532\u5305\u7b49\uff09\uff0c\u4ee5\u4e0b\u7269\u54c1\u4ecd\u9700\u81ea\u5df1\u51c6\u5907\u5e76\u5efa\u8bae\u6570\u91cf\uff1a</p> \u7269\u54c1 \u5f85\u4ea7\u5305\u5df2\u542b\uff08\u6570\u91cf\uff09 \u5efa\u8bae\u81ea\u5907\u6570\u91cf \u5907\u6ce8 \u80ce\u5fc3\u76d1\u62a4\u5e26 \u5426 1 \u6761 \u4ea7\u68c0\u4e0e\u4ea7\u623f\u7528 \u53e3\u7f69 \u5426 10\uff5e20 \u53ea \u4f4f\u9662\u53ca\u51fa\u9662\u8def\u4e0a\u7528 \u6d17\u6f31\u7528\u54c1 \u5426 1 \u5957 \u7259\u5237\u7259\u818f\u3001\u6bdb\u5dfe\u3001\u6d17\u9762\u5976\u7b49 \u9910\u5177 \u5426 1 \u5957 \u7897\u7b77/\u52fa\u3001\u53ef\u5fae\u6ce2\u7684\u996d\u76d2 \u6c34\u676f + \u5438\u7ba1 \u5426 \u5404 1 \u5438\u7ba1\u65b9\u4fbf\u4ea7\u540e\u8eba\u7740\u559d\u6c34 \u591c\u7528\u536b\u751f\u5dfe \u5426 10\uff5e15 \u7247 \u6076\u9732\u671f\uff0c\u53ef\u591a\u5907 \u536b\u751f\u7eb8 / \u62bd\u7eb8 \u5426 2\uff5e3 \u5377 / 2\uff5e3 \u5305 \u75c5\u623f\u7528 \u9632\u6ed1\u62d6\u978b \u5426 1 \u53cc \u6d17\u6fa1\u3001\u4e0b\u5730\u7528 \u5145\u7535\u5668 / \u5145\u7535\u7ebf \u5426 1 \u5957 \u624b\u673a\u7b49 \u533b\u7528\u624b\u672f\u8584\u819c \u5426 1 \u4efd \u4ec5\u987a\u4ea7\u9700\u8981\uff0c\u53ef\u5230\u533b\u9662\u5546\u5e97\u8d2d\u4e70"},{"location":"%E5%BE%85%E4%BA%A7%E5%8C%85%E5%87%86%E5%A4%87/%E5%8C%97%E5%8C%BB%E4%B8%89%E9%99%A2%E4%BA%A7%E7%A7%91%E5%85%A5%E9%99%A2%E6%B8%85%E5%8D%95/#2","title":"\u65b0\u751f\u513f\u524d 2 \u5468\u7528\u54c1\u6e05\u5355\uff08\u5c45\u5bb6\uff09","text":"<p>\u4ee5\u4e0b\u4e3a\u51fa\u9662\u56de\u5bb6\u540e\u4f7f\u7528\uff0c\u65e0\u9700\u5e26\u5165\u533b\u9662\u3002\u51fa\u9662\u56de\u5bb6\u540e\u524d 2 \u5468\u4f1a\u7528\u5230\u7684\u7269\u54c1\uff0c\u53ef\u63d0\u524d\u5907\u597d\u653e\u5728\u5bb6\u4e2d\u3002</p>"},{"location":"%E5%BE%85%E4%BA%A7%E5%8C%85%E5%87%86%E5%A4%87/%E5%8C%97%E5%8C%BB%E4%B8%89%E9%99%A2%E4%BA%A7%E7%A7%91%E5%85%A5%E9%99%A2%E6%B8%85%E5%8D%95/#_3","title":"\u8863\u7269\u4e0e\u5bdd\u5177","text":"\u7269\u54c1 \u5f85\u4ea7\u5305\u5df2\u542b\uff08\u6570\u91cf\uff09 \u5efa\u8bae\u81ea\u5907\u6570\u91cf \u5907\u6ce8 \u548c\u5c1a\u670d / \u8fde\u4f53\u8863\uff0852\uff5e59 \u7801\uff09 \u7532\u5305\u5df2\u542b\uff08\u5e94\u5b63\u8863\u670d 1 \u5957\uff0c\u4ef6\u6570\u4ee5\u533b\u9662\u4e3a\u51c6\uff09 \u518d\u5907 4\uff5e6 \u4ef6 \u524d 2 \u5468\u6362\u6d17\u9891\u7e41\uff0c\u51fa\u9662\u540e\u5c45\u5bb6\u7528 \u5e3d\u5b50 \u4e59\u5305\u5df2\u542b\u5a74\u513f\u5e3d 1 \u9876 \u53ef\u518d\u5907 0\uff5e1 \u9876 \u51fa\u9662\u53ca\u5916\u51fa\u7528 \u889c\u5b50 \u5426 2\uff5e3 \u53cc \u79cb\u51ac\u6216\u7a7a\u8c03\u623f\u7528 \u5305\u88ab / \u8941\u8913 \u7532\u5305\u5df2\u542b\u5e94\u5b63\u5305\u88ab 1 \u6761\uff1b\u4e59\u5305\u5df2\u542b\u7eb1\u5e03\u5355\u5305\u7b49 \u53ef\u518d\u5907 0\uff5e1 \u6761 \u6309\u5b63\u8282\uff0c\u53ef\u4e0e\u51fa\u9662\u5171\u7528 \u5c0f\u65b9\u5dfe / \u7eb1\u5e03\u5dfe \u7532\u5305\u5df2\u542b\u65b9\u5dfe\u3001\u7eaf\u68c9\u5305\u5355\u3001\u7eb1\u5e03\u5305\u5355\uff08\u6570\u91cf\u4ee5\u533b\u9662\u4e3a\u51c6\uff09 \u53ef\u518d\u5907 2\uff5e4 \u6761 \u57ab\u5934\u3001\u64e6\u53e3\u6c34\u3001\u62cd\u55dd\u7528 <p>\u6e29\u99a8\u63d0\u793a\uff1a\u5a74\u513f\u53ca\u4ea7\u5987\u8d34\u8eab\u8863\u7269\u3001\u5305\u88ab\u3001\u7eb1\u5e03\u5dfe\u7b49\u5efa\u8bae\u63d0\u524d\u6e05\u6d17\u540e\u518d\u4f7f\u7528\u3002\u65b0\u8863\u7269\u53ef\u80fd\u542b\u67d3\u6599\u3001\u6d46\u6599\u6216\u6b8b\u7559\u7269\uff0c\u7528\u5a74\u513f\u4e13\u7528\u6d17\u8863\u6db2/\u7682\u6d17\u4e00\u904d\u3001\u5145\u5206\u6f02\u6d17\u5e76\u667e\u5e72\uff0c\u53ef\u51cf\u5c11\u5bf9\u5b9d\u5b9d\u76ae\u80a4\u7684\u523a\u6fc0\u3002\u533b\u9662\u5f85\u4ea7\u5305\u5185\u82e5\u4e3a\u6d88\u6bd2\u5bc6\u5c01\u5305\u88c5\u53ef\u6309\u8bf4\u660e\u4f7f\u7528\uff1b\u81ea\u5907\u7684\u8863\u7269\u3001\u5bdd\u5177\u4f7f\u7528\u524d\u8bf7\u5148\u6d17\u597d\u3002</p>"},{"location":"%E5%BE%85%E4%BA%A7%E5%8C%85%E5%87%86%E5%A4%87/%E5%8C%97%E5%8C%BB%E4%B8%89%E9%99%A2%E4%BA%A7%E7%A7%91%E5%85%A5%E9%99%A2%E6%B8%85%E5%8D%95/#_4","title":"\u7eb8\u5c3f\u88e4\u4e0e\u62a4\u7406","text":"\u7269\u54c1 \u5f85\u4ea7\u5305\u5df2\u542b\uff08\u6570\u91cf\uff09 \u5efa\u8bae\u81ea\u5907\u6570\u91cf \u5907\u6ce8 NB \u7801\u7eb8\u5c3f\u88e4 \u7532\u5305\u5df2\u542b\u5a74\u513f\u7eb8\u5c3f\u88e4\uff08\u6570\u91cf\u4ee5\u533b\u9662\u4e3a\u51c6\uff0c\u4e00\u822c\u591f\u4f4f\u9662\u7528\uff09 \u51fa\u9662\u540e\u518d\u5907 1\uff5e2 \u5305\uff08\u7ea6 80\uff5e100 \u7247\uff09 \u524d 2 \u5468\u7ea6 8\uff5e12 \u7247/\u5929 \u9694\u5c3f\u57ab\uff08\u53ef\u6c34\u6d17\u6216\u4e00\u6b21\u6027\uff09 \u5426 2\uff5e3 \u5f20 / 1 \u5c0f\u5305 \u6362\u5c3f\u5e03\u65f6\u57ab\u5728\u8eab\u4e0b \u68c9\u67d4\u5dfe / \u4e91\u67d4\u5dfe \u5426 2\uff5e3 \u5305 \u64e6\u8138\u3001\u64e6\u5c41\u5c41\u3001\u64e6\u53e3\u6c34 \u5a74\u513f\u6e7f\u5dfe \u5426 1\uff5e2 \u5305 \u5916\u51fa\u6216\u4fbf\u540e\u6e05\u6d01 \u62a4\u81c0\u971c \u7532\u5305\u5df2\u542b\u5a74\u513f\u6cb9 1 \u74f6\uff08\u53ef\u4f5c\u57fa\u7840\u62a4\u7406\uff09 \u62a4\u81c0\u971c 1 \u652f \u9884\u9632\u7ea2\u5c41\u5c41\uff0c\u53ef\u4e0e\u5a74\u513f\u6cb9\u4e8c\u9009\u4e00\u6216\u642d\u914d\u7528 \u5a74\u513f\u6307\u7532\u526a / \u6307\u7532\u94b3 \u5426 1 \u4e2a \u7ea6 1 \u5468\u540e\u53ef\u5f00\u59cb\u4fee\u526a \u8033\u6e29\u67aa\u6216\u989d\u6e29\u67aa \u5426 1 \u4e2a \u6d4b\u4f53\u6e29\u7528"},{"location":"%E5%BE%85%E4%BA%A7%E5%8C%85%E5%87%86%E5%A4%87/%E5%8C%97%E5%8C%BB%E4%B8%89%E9%99%A2%E4%BA%A7%E7%A7%91%E5%85%A5%E9%99%A2%E6%B8%85%E5%8D%95/#_5","title":"\u6d17\u6d74\u4e0e\u6e05\u6d01","text":"\u7269\u54c1 \u5f85\u4ea7\u5305\u5df2\u542b\uff08\u6570\u91cf\uff09 \u5efa\u8bae\u81ea\u5907\u6570\u91cf \u5907\u6ce8 \u5a74\u513f\u6d74\u76c6\u6216\u6d17\u8138\u76c6 \u5426 1 \u4e2a \u524d 2 \u5468\u53ef\u53ea\u64e6\u6d74\uff0c\u6d74\u76c6\u53ef\u7a0d\u665a\u7528 \u6c90\u6d74\u6d17\u53d1\u4e8c\u5408\u4e00 \u5426 1 \u74f6 \u65b0\u751f\u513f\u7528\uff0c\u4e0d\u5fc5\u6bcf\u6b21\u90fd\u7528 \u6d74\u5dfe \u4e59\u5305\u5df2\u542b\u5a74\u513f\u6d74\u5dfe 1 \u6761\uff1b\u987a\u4ea7\u5305\u5df2\u542b\u5a74\u513f\u7eaf\u68c9\u6d74\u5dfe 1 \u6761 \u53ef\u518d\u5907 0\uff5e1 \u6761 \u5438\u6c34\u6027\u597d\u7684\u7eb1\u5e03\u6216\u68c9\u6d74\u5dfe"},{"location":"%E5%BE%85%E4%BA%A7%E5%8C%85%E5%87%86%E5%A4%87/%E5%8C%97%E5%8C%BB%E4%B8%89%E9%99%A2%E4%BA%A7%E7%A7%91%E5%85%A5%E9%99%A2%E6%B8%85%E5%8D%95/#_6","title":"\u5582\u517b\uff08\u6bcd\u4e73\u4e3a\u4e3b\u65f6\uff09","text":"\u7269\u54c1 \u5f85\u4ea7\u5305\u5df2\u542b\uff08\u6570\u91cf\uff09 \u5efa\u8bae\u81ea\u5907\u6570\u91cf \u5907\u6ce8 \u4e73\u5934\u971c \u5426 1 \u652f \u7f13\u89e3\u76b2\u88c2\uff0c\u54fa\u4e73\u524d\u53ef\u64e6\u62ed\u6389 \u9632\u6ea2\u4e73\u57ab \u5426 1 \u76d2\uff08\u7ea6 30\uff5e60 \u7247\uff09 \u6309\u9700\uff0c\u5976\u591a\u65f6\u7528 \u5438\u5976\u5668 \u5426 1 \u53f0 \u53ef\u9009\uff0c\u5f00\u5976\u6216\u80cc\u5976\u7528\uff1b\u524d 2 \u5468\u672a\u5fc5\u6025\u9700 \u6df7\u5408\u5582\u517b / \u5907\u7528 \u5426 \u5c0f\u7f50 1 \u6bb5\u5976\u7c89 1 \u7f50\uff08\u7ea6 400 g\uff09\u3001\u5976\u74f6 2 \u4e2a\u3001\u5976\u74f6\u5237 1 \u5957 \u5efa\u8bae\u63d0\u524d\u5907\u597d\uff1a\u51fa\u9662\u540e\u82e5\u5976\u6c34\u4e0d\u8db3\u53ef\u9a6c\u4e0a\u7528\uff0c\u7eaf\u6bcd\u4e73\u5219\u6682\u4e0d\u7528\uff08\u53ef\u9001\u4eba\u6216\u7559\u4f5c\u5e94\u6025\uff09 <p>\u4f4f\u9662\u671f\u95f4\u7981\u5e26\u5976\u74f6\u3001\u5976\u7c89\uff1b\u51fa\u9662\u540e\u82e5\u9700\u52a0\u914d\u65b9\u5976\u518d\u4f7f\u7528\u81ea\u5907\u5976\u7c89\u4e0e\u5976\u74f6\u3002</p>"},{"location":"%E5%BE%85%E4%BA%A7%E5%8C%85%E5%87%86%E5%A4%87/%E5%8C%97%E5%8C%BB%E4%B8%89%E9%99%A2%E4%BA%A7%E7%A7%91%E5%85%A5%E9%99%A2%E6%B8%85%E5%8D%95/#_7","title":"\u7761\u7720\u4e0e\u5b89\u5168","text":"\u7269\u54c1 \u5f85\u4ea7\u5305\u5df2\u542b\uff08\u6570\u91cf\uff09 \u5efa\u8bae\u81ea\u5907\u6570\u91cf \u5907\u6ce8 \u5a74\u513f\u5e8a / \u62fc\u63a5\u5e8a / \u6447\u7bee \u7532\u5305\u5df2\u542b\u5c0f\u8925\u5b50\u3001\u7761\u888b\u3001\u5c0f\u6795\u5934\uff08\u75c5\u623f\u7528\uff09 \u5bb6\u7528\u5e8a/\u6447\u7bee 1 \u6309\u5bb6\u91cc\u7a7a\u95f4\u9009\uff0c\u786e\u4fdd\u5e8a\u54c1\u5e73\u6574\u3001\u65e0\u591a\u4f59\u6742\u7269 \u51fa\u9662\u7528\u8f66 \u5426 \u2014 \u5efa\u8bae\u4f7f\u7528\u5a74\u513f\u5b89\u5168\u5ea7\u6905\u6216\u63d0\u7bee\uff08\u51fa\u9662\u5373\u9700\uff09"},{"location":"%E5%BE%85%E4%BA%A7%E5%8C%85%E5%87%86%E5%A4%87/%E5%8C%97%E5%8C%BB%E4%B8%89%E9%99%A2%E4%BA%A7%E7%A7%91%E5%85%A5%E9%99%A2%E6%B8%85%E5%8D%95/#_8","title":"\u5176\u4ed6","text":"<ul> <li>\u51fa\u9662\u5f53\u5929\uff1a\u5e3d\u5b50\u3001\u8863\u670d\u3001\u7eb8\u5c3f\u88e4\u3001\u5305\u88ab\uff08\u6e05\u5355\u300c04 \u51fa\u9662\u7528\u7269\u300d\u5df2\u5217\uff0c\u53ef\u4e0e\u524d 2 \u5468\u7528\u54c1\u5171\u7528\uff09\u3002</li> <li>\u524d 2 \u5468\u4ee5\u5403\u3001\u7761\u3001\u6362\u5c3f\u5e03\u3001\u7b80\u5355\u62a4\u7406\u4e3a\u4e3b\uff0c\u4e0d\u5fc5\u4e00\u6b21\u4e70\u9f50\u6240\u6709\u6708\u9f84\u7528\u54c1\uff1b\u5976\u74f6\u3001\u6d88\u6bd2\u5668\u3001\u6e29\u5976\u5668\u7b49\u53ef\u7b49\u5582\u517b\u65b9\u5f0f\u7a33\u5b9a\u540e\u518d\u6dfb\u3002</li> </ul>"},{"location":"%E5%BE%85%E4%BA%A7%E5%8C%85%E5%87%86%E5%A4%87/%E5%8C%97%E5%8C%BB%E4%B8%89%E9%99%A2%E4%BA%A7%E7%A7%91%E5%85%A5%E9%99%A2%E6%B8%85%E5%8D%95/#_9","title":"\u81ea\u5907\u7269\u54c1\u63a8\u